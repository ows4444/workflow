{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    // "isolatedModules": true, // This is required for the `tsc` compiler to work with decorators, but it can cause issues with some libraries. Set to false to avoid issues.
    "types": ["node", "jest"],
    "declaration": true,
    "removeComments": true,
    "isolatedModules": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/workflow": ["libs/workflow/src"],
      "@/workflow/*": ["libs/workflow/src/*"]
    }
  }
}
